{
    "name": "@getmikk/vscode-extension",
    "displayName": "Mikk - Codebase Nervous System",
    "description": "VS Code extension for Mikk — see your architecture, get AI context, detect impact",
    "version": "1.2.0",
    "license": "Apache-2.0",
    "publisher": "mikk-dev",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other",
        "Visualization"
    ],
    "activationEvents": [
        "workspaceContains:mikk.json"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "mikk.init",
                "title": "Mikk: Initialize"
            },
            {
                "command": "mikk.analyze",
                "title": "Mikk: Analyze"
            },
            {
                "command": "mikk.showDiagram",
                "title": "Mikk: Show Architecture Diagram"
            },
            {
                "command": "mikk.showImpact",
                "title": "Mikk: Show Impact Analysis"
            },
            {
                "command": "mikk.getContext",
                "title": "Mikk: Get AI Context"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "mikk-explorer",
                    "title": "Mikk",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "mikk-explorer": [
                {
                    "id": "mikkModules",
                    "name": "Modules",
                    "icon": "resources/icon.svg"
                },
                {
                    "id": "mikkFunctions",
                    "name": "Functions",
                    "icon": "resources/icon.svg"
                },
                {
                    "id": "mikkHealth",
                    "name": "Health",
                    "icon": "resources/icon.svg"
                }
            ]
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Ansh-dhanani/mikk"
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc --watch",
        "package": "npx -y @vscode/vsce package",
        "deploy": "npx -y @vscode/vsce publish"
    },
    "dependencies": {
        "@getmikk/core": "^1.2.0",
        "@getmikk/diagram-generator": "^1.2.0",
        "@getmikk/ai-context": "^1.2.0"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "typescript": "^5.7.0"
    }
}