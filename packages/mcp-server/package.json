{
    "name": "@getmikk/mcp-server",
    "version": "1.5.0",
    "license": "Apache-2.0",
    "description": "MCP (Model Context Protocol) server for Mikk — exposes project intelligence to AI assistants",
    "repository": {
        "type": "git",
        "url": "https://github.com/Ansh-dhanani/mikk"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "bin": {
        "mikk-mcp": "bin/mikk-mcp.js"
    },
    "exports": {
        ".": {
            "import": "./dist/index.cjs",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "bin"
    ],
    "scripts": {
        "build": "node esbuild.mjs",
        "test": "bun test",
        "dev": "tsc --watch"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "better-sqlite3": "^12.6.2"
    },
    "devDependencies": {
        "@getmikk/core": "workspace:*",
        "@getmikk/ai-context": "workspace:*",
        "@getmikk/intent-engine": "workspace:*",
        "@types/node": "^22.0.0",
        "esbuild": "^0.21.4",
        "typescript": "^5.7.0",
        "zod": "^3.24.0"
    }
}
